#!/bin/sh

INPUT=$(cat)
TYPE=$(echo "$INPUT" | jq -r '.notification_type // "unknown"')

# Tmux context (session:window) or fallback to cwd
if [ -n "$TMUX_PANE" ]; then
  CONTEXT=$(tmux display-message -p -t "$TMUX_PANE" '#S:#W')
else
  CONTEXT=$(basename "$PWD")
fi

# Map type to message + sound
case "$TYPE" in
  permission_prompt)
    notify "Claude: $CONTEXT" "needs permission" \
      /System/Library/Sounds/Funk.aiff
    ;;
  *)
    notify "Claude: $CONTEXT" "done"
    ;;
esac
